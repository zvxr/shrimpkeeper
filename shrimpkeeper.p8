pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

#include ent.lua
#include physics.lua
#include tank.lua
#include shop.lua
#include shrimp.lua
#include snail.lua
#include algae.lua
#include micro.lua
#include moss.lua
#include player.lua
#include spawn.lua

ver="v2026.3"

function init_title()
	gs=0
	ts=1
	th=0
	pl=nil
	tank=nil
	ent={}
	ha=nil
	sd_a=nil
end

function _init()
	cartdata("shrimpkeeper")
	hs=max(100,dget(0))
	init_title()
end

function _update()
	if gs==0 then
		if th==0 then
			if btnp(2) or btnp(3) then ts=3-ts end
			if btnp(5) then
				if ts==1 then
					init_world()
					gs=1
				else
					th=1
				end
			end
		elseif btnp(5) then
			th+=1
			if th>2 then
				th=0
				ts=1
			end
		end
		return
	end
	if tank.go then
		if tank.got>0 then
			tank.got-=1
		elseif btnp(5) then
			init_title()
		end
		return
	end
	if sd_a then
		if any_btn() then sd_a=nil end
		return
	end
	if tank.sm>0 then
		upd_shop()
		return
	end
	upd_tank()
	control_player(pl)
	upd_shrimp()
	upd_snail()
	upd_algae()
	foreach(ent, move_ent)
	try_door(pl)
	try_pet(pl)
end

function _draw()
	if gs==0 then
		camera()
		cls()
		local x=th*16
		camera(x*8,16*8)
		map(x,16,x*8,16*8,16,16)
		camera()
		if th==0 then
			print(ver,85,105,5)
			print(ts==1 and ">start" or " start",46,64,7)
			print(ts==2 and ">help" or " help",46,72,7)
			print("hi score",46,80,7)
			print(flr(hs),46,88,7)
		end
		return
	end
	camera()
	cls()

	room_x=flr(pl.x/16)
	room_y=flr(pl.y/16)
	camera(room_x*128,room_y*128)
	map(room_x*16,room_y*16,room_x*128,room_y*128,16,16)
	if s2_ok() then spr(12,25*8,4*8) end
	if s4_ok() then spr(14,33*8,11*8) end
	if s5_ok() then spr(15,30*8,10*8) end
	if tank.day>=12 then spr(13,45*8,5*8) end
	if tank.day>=19 then spr(31,53*8,4*8) end
	if s7_ok() then spr(63,1*8,14*8) end
	foreach(ent,draw_ent)
	draw_held_pet()
	camera()
	draw_tank_hud()
	if tank.sm>0 then draw_shop() end
	if sd_a then draw_pet_dialog(sd_a) end
	if tank.go then draw_go() end
end

