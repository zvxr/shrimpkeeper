pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- ent physics
-- by zep
-- edited version for shrimp

#include ent.lua
#include physics.lua
#include player.lua
#include spawn.lua

function _init()
	init_world()
end

function _update()
	control_player(pl)
	foreach(ent, move_ent)
end

function _draw()
	camera()
	cls()

	room_x=flr(pl.x/16)
	room_y=flr(pl.y/16)
	camera(room_x*128,room_y*128)
	map(room_x*16,room_y*16,room_x*128,room_y*128,16,16)
	foreach(ent,draw_ent)
	camera()
	print("money: "..pl.money,64,9,7)
end

