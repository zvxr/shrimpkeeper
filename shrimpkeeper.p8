pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

#include ent.lua
#include physics.lua
#include tank.lua
#include shrimp.lua
#include player.lua
#include spawn.lua

function _init()
	init_world()
end

function _update()
	if sd_a then
		if any_btn() then sd_a=nil end
		return
	end
	upd_tank()
	control_player(pl)
	upd_shrimp()
	foreach(ent, move_ent)
	try_door(pl)
	try_shrimp(pl)
end

function _draw()
	camera()
	cls()

	room_x=flr(pl.x/16)
	room_y=flr(pl.y/16)
	camera(room_x*128,room_y*128)
	map(room_x*16,room_y*16,room_x*128,room_y*128,16,16)
	foreach(ent,draw_ent)
	draw_held_shrimp()
	camera()
	draw_tank_hud()
	if sd_a then draw_shrimp_dialog(sd_a) end
end

