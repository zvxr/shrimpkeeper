pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

#include ent.lua
#include physics.lua
#include tank.lua
#include shop.lua
#include shrimp.lua
#include snail.lua
#include micro.lua
#include moss.lua
#include player.lua
#include spawn.lua

function _init()
	init_world()
end

function _update()
	if tank.go then return end
	if sd_a then
		if any_btn() then sd_a=nil end
		return
	end
	if tank.sm>0 then
		upd_shop()
		return
	end
	upd_tank()
	control_player(pl)
	upd_shrimp()
	upd_snail()
	foreach(ent, move_ent)
	try_door(pl)
	try_pet(pl)
end

function _draw()
	camera()
	cls()

	room_x=flr(pl.x/16)
	room_y=flr(pl.y/16)
	camera(room_x*128,room_y*128)
	map(room_x*16,room_y*16,room_x*128,room_y*128,16,16)
	if tank.ps then spr(12,25*8,4*8) end
	if disc_ok() then spr(14,33*8,11*8) end
	if tank.day>=10 then spr(13,45*8,5*8) end
	foreach(ent,draw_ent)
	draw_held_pet()
	camera()
	draw_tank_hud()
	if tank.sm>0 then draw_shop() end
	if sd_a then draw_pet_dialog(sd_a) end
	if tank.go then draw_go() end
end

